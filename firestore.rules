rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function dashboardUserPath(weddingId) {
      return /databases/$(database)/documents/weddings/$(weddingId)/dashboardUsers/$(request.auth.uid);
    }

    function dashboardUser(weddingId) {
      return get(dashboardUserPath(weddingId));
    }

    function isDashboardMember(weddingId) {
      return isSignedIn() && exists(dashboardUserPath(weddingId));
    }

    function canViewDashboard(weddingId) {
      return isDashboardMember(weddingId) &&
        dashboardUser(weddingId).data.canViewDashboard == true;
    }

    function canEditGuests(weddingId) {
      return isDashboardMember(weddingId) &&
        dashboardUser(weddingId).data.canEditGuests == true;
    }

    function isSeatingManager(weddingId) {
      return isSeatingEditor(weddingId) &&
        request.auth.token.seatingRole in ["bride", "groom"];
    }

    function canEditSeating(weddingId) {
      return (isDashboardMember(weddingId) &&
        dashboardUser(weddingId).data.canEditSeating == true) || isSeatingManager(weddingId);
    }

    // Editor links are exchanged by Cloud Functions for custom Firebase Auth
    // tokens. The live access record is checked on every Firestore request,
    // which makes revoke/regenerate effective for already-open sessions too.
    function seatingAccess(weddingId, role) {
      return get(/databases/$(database)/documents/weddings/$(weddingId)/seatingAccess/$(role));
    }

    function isSeatingEditor(weddingId) {
      return isSignedIn()
        && request.auth.token.seatingEditor == true
        && request.auth.token.seatingWeddingId == weddingId
        && request.auth.token.seatingRole in ["bride", "groom", "family"]
        && seatingAccess(weddingId, request.auth.token.seatingRole).data.status == "active"
        && seatingAccess(weddingId, request.auth.token.seatingRole).data.version == request.auth.token.seatingAccessVersion;
    }

    function canReadSeating(weddingId) {
      return canViewDashboard(weddingId) || isSeatingEditor(weddingId);
    }

    function normalizedGuestSide(guest) {
      return guest.side in ["bride", "Bride", "bride side", "Bride Side"] ? "bride" :
        (guest.side in ["groom", "Groom", "groom side", "Groom Side"] ? "groom" :
        (guest.side in ["both", "Both", "both sides", "Both Sides", "shared", "Shared"] ? "both" : "family"));
    }

    function editorMayReadGuest(guest) {
      // Bride and Groom managers work from one shared floor plan, so both
      // need the complete guest roster. Family links keep their existing
      // limited view and never receive write authority.
      return request.auth.token.seatingRole in ["bride", "groom"]
        || (request.auth.token.seatingRole == "family" && normalizedGuestSide(guest) == "family");
    }

    function editorMayUpdatePublicGuest(weddingId, publicGuest) {
      return !isSeatingEditor(weddingId) || (publicGuest.guestId is string
        && editorMayReadGuest(get(/databases/$(database)/documents/weddings/$(weddingId)/guests/$(publicGuest.guestId)).data));
    }

    function canCheckIn(weddingId) {
      return isDashboardMember(weddingId) &&
        dashboardUser(weddingId).data.canCheckIn == true;
    }

    function canManageUsers(weddingId) {
      return isDashboardMember(weddingId) &&
        dashboardUser(weddingId).data.canManageUsers == true;
    }

    function isPublicWedding(weddingId) {
      return get(/databases/$(database)/documents/weddings/$(weddingId)).data.status == "active";
    }

    function isGuestRsvpUpdate(weddingId) {
      return isPublicWedding(weddingId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["rsvpStatus", "additionalGuests", "updatedAt"])
        && request.resource.data.guestToken == resource.data.guestToken
        && request.resource.data.rsvpStatus in ["pending", "confirmed", "declined"]
        && request.resource.data.additionalGuests is int
        && request.resource.data.additionalGuests >= 0
        && request.resource.data.additionalGuests <= 10
        && request.resource.data.updatedAt == request.time;
    }

    function isGuestSeatingUpdate(weddingId) {
      // Dashboard seating accounts can update every guest's seat assignment.
      // The side filter applies only to the legacy custom-token editor links.
      return canEditSeating(weddingId) &&
        (!isSeatingEditor(weddingId) || editorMayReadGuest(resource.data))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "tableId",
          "tableName",
          "seatNumber",
          "seatingAssignments",
          "updatedAt"
        ]);
    }

    match /weddings/{weddingId} {
      allow read: if canViewDashboard(weddingId) || resource.data.status == "active";

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerUserId;

      // Table positions are stored in their own table documents, but the
      // stage/entrance markers live on the wedding document. Let seating
      // editors update only that layout field, without granting access to any
      // other wedding settings.
      allow update: if (isDashboardMember(weddingId) &&
          request.auth.uid == resource.data.ownerUserId)
        || ((isDashboardMember(weddingId) && dashboardUser(weddingId).data.canEditSeating == true)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["hallObjects", "updatedAt"]));

      allow delete: if isDashboardMember(weddingId) &&
        request.auth.uid == resource.data.ownerUserId;

      match /dashboardUsers/{userId} {
        allow read: if isDashboardMember(weddingId);
        allow create, update, delete: if canManageUsers(weddingId);
      }

      match /seatingAccess/{role} {
        allow read: if (isDashboardMember(weddingId) &&
          request.auth.uid == get(/databases/$(database)/documents/weddings/$(weddingId)).data.ownerUserId)
          || canManageUsers(weddingId);
        allow write: if false;
      }

      match /tables/{tableId} {
        allow read: if canReadSeating(weddingId) || isPublicWedding(weddingId);
        allow create, delete: if isDashboardMember(weddingId) &&
          dashboardUser(weddingId).data.canEditSeating == true;
        // Secure link managers can only change occupancy; table geometry,
        // names, capacity, and chair positions stay dashboard-only.
        allow update: if (isDashboardMember(weddingId) &&
            dashboardUser(weddingId).data.canEditSeating == true)
          || (isSeatingManager(weddingId) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["chairs", "guestIds", "updatedAt"]));
      }

      match /guests/{guestId} {
        // Editor links may read only the guest documents for their authorized
        // side. Collection queries must include the matching side values.
        allow get: if canViewDashboard(weddingId) || (isSeatingEditor(weddingId) && editorMayReadGuest(resource.data));
        allow list: if canViewDashboard(weddingId) || (isSeatingEditor(weddingId) && editorMayReadGuest(resource.data));
        allow create, delete: if canEditGuests(weddingId);
        allow update: if canEditGuests(weddingId) || canCheckIn(weddingId) || isGuestRsvpUpdate(weddingId) || isGuestSeatingUpdate(weddingId);
      }

      // Aggregated side-level stats (counts + seated roster, no phones or
      // tokens) published by the dashboard for the read-only side.html pages.
      match /publicStats/{docId} {
        allow get: if isPublicWedding(weddingId) || canViewDashboard(weddingId);
        allow list: if false;
        allow create, update, delete: if isDashboardMember(weddingId);
      }

      match /publicGuests/{guestToken} {
        // Seating transactions read the matching public mirror before they
        // update it. Permit the seat-only dashboard accounts to do that even
        // while an invitation is not publicly active.
        allow get: if isPublicWedding(weddingId) || canEditSeating(weddingId);
        allow list: if false;
        // Dashboard members maintain this token-keyed mirror of guest-facing
        // fields so invitation/check-in pages can load guests without list access.
        // Check-in-only and seating-only members may patch exactly the fields
        // their role owns. Holding the token (it is the doc id) also authorizes
        // a guest to update their own RSVP answer, mirroring the guests rule.
        allow create, delete: if canEditGuests(weddingId);
        allow update: if canEditGuests(weddingId)
          || (canCheckIn(weddingId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["checkedIn", "checkedInAt", "updatedAt"]))
          || (canEditSeating(weddingId) && editorMayUpdatePublicGuest(weddingId, resource.data)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["seatingAssignments", "tableId", "tableName", "seatNumber", "updatedAt"]))
          || (isPublicWedding(weddingId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(["rsvpStatus", "additionalGuests", "updatedAt"])
            && request.resource.data.rsvpStatus in ["pending", "confirmed", "declined"]
            && request.resource.data.additionalGuests is int
            && request.resource.data.additionalGuests >= 0
            && request.resource.data.additionalGuests <= 10
            && request.resource.data.updatedAt == request.time);
      }
    }
  }
}
